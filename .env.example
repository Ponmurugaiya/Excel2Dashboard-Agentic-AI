# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Primary LLM: Google Gemini ────────────────────────────────────────────────
# Required — get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Optional — defaults to gemini-1.5-flash
# Other options: gemini-1.5-pro, gemini-2.0-flash-exp, gemini-2.5-flash
GEMINI_MODEL=gemini-1.5-flash

# ── Fallback LLM: Groq ────────────────────────────────────────────────────────
# Recommended — used automatically when Gemini hits rate limits
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional — defaults to llama-3.3-70b-versatile
# Other fast options: llama-3.1-8b-instant, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ── Auth ──────────────────────────────────────────────────────────────────────
# Optional — change this to a random string in production
JWT_SECRET=change-me-in-production-please
